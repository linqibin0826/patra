<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.patra</groupId>
        <artifactId>patra-common</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>patra-common-test</artifactId>
    <packaging>jar</packaging>
    <name>Patra Common Test</name>
    <description>
        纯 Java 测试工具库,提供通用的测试数据构建器、Mock 数据工厂和断言辅助类:
        - TestDataBuilder: 测试数据构建器抽象基类
        - MockDataFactory: Mock 数据工厂(随机数据生成)
        - DomainAssertions: 领域断言工具
        - AssertionHelper: 通用断言辅助类
        - BaseUnitTest: 单元测试基类
        - TestConstants: 测试常量定义
    </description>

    <dependencies>
        <!-- JUnit 5 (Jupiter) - 测试框架核心 -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-api</artifactId>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-params</artifactId>
        </dependency>

        <!-- Mockito - Mock 框架 -->
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
        </dependency>

        <!-- AssertJ - 流式断言库 -->
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
        </dependency>

        <!-- SLF4J API - 日志接口(provided,由运行时提供) -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- 注意: 本模块不依赖 Spring 框架,保持纯 Java 特性 -->
    </dependencies>

    <build>
        <plugins>
            <!-- JaCoCo 测试覆盖率 -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <configuration>
                            <includes>
                                <include>com/patra/**</include>
                            </includes>
                        </configuration>
                    </execution>
                    <execution>
                        <id>check</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.80</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
