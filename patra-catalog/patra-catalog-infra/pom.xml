<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.patra</groupId>
        <artifactId>patra-catalog</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>patra-catalog-infra</artifactId>
    <name>Patra Catalog Infrastructure</name>
    <description>Data persistence infrastructure module - MySQL and Elasticsearch persistence</description>

    <dependencies>
        <!-- ================================ -->
        <!-- 内部模块依赖 -->
        <!-- ================================ -->
        <!-- 领域层核心 -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-catalog-domain</artifactId>
        </dependency>

        <!-- 通用模型定义 -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-common-model</artifactId>
        </dependency>

        <!-- ================================ -->
        <!-- 数据持久化 -->
        <!-- ================================ -->
        <!-- MyBatis 持久化（MySQL） -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-mybatis</artifactId>
        </dependency>

        <!-- Elasticsearch 持久化 -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-elasticsearch</artifactId>
        </dependency>

        <!-- ================================ -->
        <!-- 外部通信 -->
        <!-- ================================ -->
        <!-- Feign 远程调用 -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-cloud-starter-feign</artifactId>
        </dependency>

        <!-- 负载均衡器 -->
        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-loadbalancer</artifactId>
        </dependency>

        <!-- RestClient HTTP 客户端（用于文件下载） -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-rest-client</artifactId>
        </dependency>

        <!-- ================================ -->
        <!-- 事件发布 -->
        <!-- ================================ -->
        <!-- RocketMQ 消息队列 -->
        <dependency>
            <groupId>org.apache.rocketmq</groupId>
            <artifactId>rocketmq-spring-boot-starter</artifactId>
        </dependency>

        <!-- ================================ -->
        <!-- 工具库 -->
        <!-- ================================ -->
        <!-- MapStruct 对象转换 -->
        <dependency>
            <groupId>org.mapstruct</groupId>
            <artifactId>mapstruct</artifactId>
        </dependency>

        <!-- Hutool 加密工具（MD5 校验） -->
        <dependency>
            <groupId>cn.hutool</groupId>
            <artifactId>hutool-crypto</artifactId>
        </dependency>

        <!-- ================================ -->
        <!-- Spring 框架 -->
        <!-- ================================ -->
        <!-- Spring Boot 核心 -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>

        <!-- ================================ -->
        <!-- 测试依赖 -->
        <!-- ================================ -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <!-- MyBatis-Plus 测试支持（@MybatisPlusTest） -->
        <dependency>
            <groupId>com.baomidou</groupId>
            <artifactId>mybatis-plus-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>

                </executions>
            </plugin>
        </plugins>
    </build>

</project>
