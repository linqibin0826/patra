<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.patra.registry.infra.persistence.mapper.provenance.RegProvRateLimitCfgMapper">

    <!--
      Reusable WHERE clause for temporal slicing and operation-type precedence.
      Filters for active configs effective at the query timestamp.
    -->
    <sql id="activeConfigFilter">
        WHERE deleted = 0
          AND lifecycle_status_code = 'ACTIVE'
          AND provenance_id = #{provenanceId}
          AND effective_from &lt;= #{now}
          AND (effective_to IS NULL OR effective_to &gt; #{now})
          AND operation_type IN (#{operationType}, 'ALL')
    </sql>

    <!--
      Reusable ORDER BY clause enforcing operation-specific precedence.
      Orders by: 1) operation match (exact > ALL), 2) latest effective_from, 3) latest id.
    -->
    <sql id="operationPrecedenceOrder">
        ORDER BY
          CASE WHEN operation_type = #{operationType} THEN 1 ELSE 2 END,
          effective_from DESC,
          id DESC
    </sql>

    <!--
      Retrieves the effective rate limit configuration scoped by provenance and operation.
    -->
    <select id="selectActiveMerged" resultType="com.patra.registry.infra.persistence.entity.provenance.RegProvRateLimitCfgDO">
        SELECT *
        FROM patra_registry.reg_prov_rate_limit_cfg
        <include refid="activeConfigFilter"/>
        <include refid="operationPrecedenceOrder"/>
        LIMIT 1
    </select>

</mapper>
