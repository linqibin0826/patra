{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/mark-java-changes.sh\"",
            "statusMessage": "记录 Java 文件变更"
          }
        ],
        "matcher": "Edit|Write|apply_patch"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/gradle-compile-check.sh\"",
            "statusMessage": "运行 Gradle 编译检查",
            "timeout": 600
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/send-stop-notification.sh\"",
            "statusMessage": "发送停止通知",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
