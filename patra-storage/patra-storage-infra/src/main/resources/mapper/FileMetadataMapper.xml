<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.patra.storage.infra.persistence.mapper.FileMetadataMapper">

    <resultMap id="FileMetadataResultMap" type="com.patra.storage.infra.persistence.entity.FileMetadataDO">
        <id property="id" column="id" />
        <result property="storageKey" column="storage_key" />
        <result property="bucketName" column="bucket_name" />
        <result property="objectKey" column="object_key" />
        <result property="fileSize" column="file_size" />
        <result property="contentType" column="content_type" />
        <result property="md5Hash" column="md5_hash" />
        <result property="sha256Hash" column="sha256_hash" />
        <result property="serviceName" column="service_name" />
        <result property="businessType" column="business_type" />
        <result property="businessId" column="business_id" />
        <result property="correlationData" column="correlation_data" jdbcType="OTHER" />
        <result property="providerType" column="provider_type" />
        <result property="fileStatus" column="file_status" />
        <result property="uploadedAt" column="uploaded_at" />
        <result property="expiresAt" column="expires_at" />
        <result property="deletedAt" column="deleted_at" />
        <result property="recordRemarks" column="record_remarks" />
        <result property="version" column="version" />
        <result property="ipAddress" column="ip_address" />
        <result property="createdAt" column="created_at" />
        <result property="createdBy" column="created_by" />
        <result property="createdByName" column="created_by_name" />
        <result property="updatedAt" column="updated_at" />
        <result property="updatedBy" column="updated_by" />
        <result property="updatedByName" column="updated_by_name" />
        <result property="deleted" column="deleted" />
    </resultMap>

    <select id="findByStorageKey" resultMap="FileMetadataResultMap">
        SELECT
            id,
            storage_key,
            bucket_name,
            object_key,
            file_size,
            content_type,
            md5_hash,
            sha256_hash,
            service_name,
            business_type,
            business_id,
            correlation_data,
            provider_type,
            file_status,
            uploaded_at,
            expires_at,
            deleted_at,
            record_remarks,
            version,
            ip_address,
            created_at,
            created_by,
            created_by_name,
            updated_at,
            updated_by,
            updated_by_name,
            deleted
        FROM storage_file_metadata
        WHERE storage_key = #{storageKey}
        LIMIT 1
    </select>
</mapper>
