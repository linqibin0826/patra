<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter for Patra project.

  This file excludes false positives and known safe patterns from SpotBugs analysis.
  Customize as needed based on your project's specific requirements.

  Documentation: https://spotbugs.readthedocs.io/en/stable/filter.html
-->
<FindBugsFilter>

  <!-- ========================================================================
       GENERATED CODE EXCLUSIONS
       ======================================================================== -->

  <!-- Exclude Lombok-generated code -->
  <Match>
    <Class name="~.*\..*_\$.*"/>
    <Bug pattern="NP_NULL_PARAM_DEREF_ALL_TARGETS_DANGEROUS"/>
  </Match>

  <!-- Exclude MapStruct-generated mappers -->
  <Match>
    <Class name="~.*MapperImpl$"/>
  </Match>

  <!-- Exclude Spring Boot generated configuration metadata -->
  <Match>
    <Class name="~.*ConfigurationProperties.*"/>
    <Bug pattern="URF_UNREAD_FIELD"/>
  </Match>

  <!-- ========================================================================
       DATA OBJECTS (DO) AND DTOs
       ======================================================================== -->

  <!-- Data Objects are simple data containers - serialization warnings OK -->
  <Match>
    <Class name="~.*DO$"/>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
      <Bug pattern="SE_BAD_FIELD"/>
    </Or>
  </Match>

  <!-- DTOs may have mutable fields for flexibility -->
  <Match>
    <Class name="~.*DTO$"/>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- API modules (contracts) expose mutable objects for flexibility -->
  <Match>
    <Package name="~.*\.api\..*"/>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
      <Bug pattern="SE_BAD_FIELD"/>
    </Or>
  </Match>

  <!-- ========================================================================
       SPRING FRAMEWORK PATTERNS
       ======================================================================== -->

  <!-- Spring autowired fields (constructor injection preferred, but field injection used) -->
  <Match>
    <Or>
      <Class name="~.*Controller$"/>
      <Class name="~.*Orchestrator$"/>
      <Class name="~.*Job$"/>
    </Or>
    <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
  </Match>

  <!-- Spring @Value injected fields -->
  <Match>
    <Bug pattern="UWF_NULL_FIELD"/>
    <Field name="~.*" annotation="org.springframework.beans.factory.annotation.Value"/>
  </Match>

  <!-- Spring @ConfigurationProperties expose mutable collections by design -->
  <Match>
    <Or>
      <Class name="~.*Properties$"/>
      <Class name="~.*Config$"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
      <Bug pattern="URF_UNREAD_FIELD"/>
    </Or>
  </Match>

  <!-- Error handling infrastructure may expose internal representation -->
  <Match>
    <Package name="~.*\.error\..*"/>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
      <Bug pattern="MS_EXPOSE_REP"/>
      <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
      <Bug pattern="NP_NULL_PARAM_DEREF"/>
      <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
      <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
    </Or>
  </Match>

  <!-- Web response wrappers expose mutable collections by design -->
  <Match>
    <Package name="~.*\.resp.*"/>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
    </Or>
  </Match>

  <!-- ========================================================================
       INTENTIONAL DESIGN PATTERNS
       ======================================================================== -->

  <!-- Builder pattern intentionally returns mutable object -->
  <Match>
    <Class name="~.*Builder$"/>
    <Method name="build"/>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>

  <!-- Factory methods may intentionally expose internal representation -->
  <Match>
    <Method name="~create.*|~build.*|~of"/>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>

  <!-- Domain aggregates and VOs intentionally expose internal representation -->
  <Match>
    <Or>
      <Class name="~.*\.domain\.model\.aggregate\..*"/>
      <Class name="~.*\.domain\.model\.vo\..*"/>
      <Class name="~.*\.domain\.model\.entity\..*"/>
    </Or>
    <Or>
      <Bug pattern="EI_EXPOSE_REP"/>
      <Bug pattern="EI_EXPOSE_REP2"/>
      <Bug pattern="SE_BAD_FIELD"/>
    </Or>
  </Match>

  <!-- Domain policies may validate in constructors (throw by design) -->
  <Match>
    <Class name="~.*\.domain\.policy\..*"/>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
  </Match>

  <!-- Boxing inefficiencies in domain models are acceptable for clarity -->
  <Match>
    <Package name="~.*\.domain\..*"/>
    <Bug pattern="BX_UNBOXING_IMMEDIATELY_REBOXED"/>
  </Match>

  <!-- ========================================================================
       JACKSON/JSON SERIALIZATION
       ======================================================================== -->

  <!-- Jackson requires default constructors for deserialization -->
  <Match>
    <Or>
      <Class name="~.*Request$"/>
      <Class name="~.*Response$"/>
      <Class name="~.*DTO$"/>
    </Or>
    <Bug pattern="UWF_UNREAD_PUBLIC_OR_PROTECTED_FIELD"/>
  </Match>

  <!-- ========================================================================
       TEST CODE
       ======================================================================== -->

  <!-- Test fixtures may have unused fields -->
  <Match>
    <Class name="~.*Test$"/>
    <Or>
      <Bug pattern="UWF_UNREAD_FIELD"/>
      <Bug pattern="URF_UNREAD_FIELD"/>
      <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    </Or>
  </Match>

  <!-- Test helper classes -->
  <Match>
    <Class name="~.*TestUtil$"/>
    <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD"/>
  </Match>

  <!-- ========================================================================
       JPA AND PERSISTENCE
       ======================================================================== -->

  <!-- JPA entity fields are accessed via reflection -->
  <Match>
    <Class name="~.*DO$"/>
    <Or>
      <Bug pattern="UWF_UNREAD_FIELD"/>
      <Bug pattern="URF_UNREAD_FIELD"/>
    </Or>
  </Match>

  <!-- Repository implementations may have seemingly unused methods (called by framework) -->
  <Match>
    <Class name="~.*RepositoryAdapter$"/>
    <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD"/>
  </Match>

  <!-- ========================================================================
       PERFORMANCE FALSE POSITIVES
       ======================================================================== -->

  <!-- String concatenation in logging (guarded by isDebugEnabled in code) -->
  <Match>
    <Or>
      <Class name="~.*Orchestrator$"/>
      <Class name="~.*Controller$"/>
    </Or>
    <Bug pattern="SBSC_USE_STRINGBUFFER_CONCATENATION"/>
  </Match>

  <!-- ========================================================================
       SECURITY: INTENTIONAL EXCLUSIONS
       ======================================================================== -->

  <!-- Exclude SQL injection warnings for JPA/Hibernate (uses parameterized queries) -->
  <Match>
    <Class name="~.*RepositoryAdapter$"/>
    <Bug pattern="SQL_INJECTION_HIBERNATE"/>
  </Match>

  <!-- ========================================================================
       KNOWN SAFE PATTERNS
       ======================================================================== -->

  <!-- Immutable value objects intentionally return same instance -->
  <Match>
    <Package name="~.*\.domain\.model\.vo.*"/>
    <Bug pattern="RV_RETURN_VALUE_IGNORED"/>
  </Match>

  <!-- Hutool utilities may have "dangerous" methods that are safe in context -->
  <Match>
    <Class name="~cn\.hutool\..*"/>
  </Match>

  <!-- ========================================================================
       CUSTOM EXCLUSIONS (Add project-specific exclusions below)
       ======================================================================== -->

  <!-- ApplicationException: Constructor throws by design (exception class) -->
  <Match>
    <Class name="com.patra.common.error.ApplicationException"/>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
  </Match>

  <!-- JsonNormalizerResult: Internal result class, exposing hash material is intentional -->
  <Match>
    <Class name="com.patra.common.json.JsonNormalizer$Result"/>
    <Method name="getHashMaterial"/>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>

  <!-- ObjectMapperProvider: Singleton pattern with static field by design -->
  <Match>
    <Class name="com.patra.starter.core.json.ObjectMapperProvider"/>
    <Or>
      <Bug pattern="MS_EXPOSE_REP"/>
      <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Or>
  </Match>

</FindBugsFilter>
