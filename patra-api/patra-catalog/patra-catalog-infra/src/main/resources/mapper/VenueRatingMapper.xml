<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.patra.catalog.infra.persistence.mapper.VenueRatingMapper">

  <!-- 清空表（DDL 操作，会隐式提交事务） -->
  <update id="truncateTable">
    TRUNCATE TABLE cat_venue_rating
  </update>

  <!-- 物理删除指定 venue 的所有评级记录（绕过 @TableLogic） -->
  <delete id="physicalDeleteByVenueIds">
    DELETE FROM cat_venue_rating WHERE venue_id IN
    <foreach collection="venueIds" item="id" open="(" separator="," close=")">
      #{id}
    </foreach>
  </delete>

</mapper>
