<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.patra</groupId>
        <artifactId>patra-catalog</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>patra-catalog-boot</artifactId>
    <name>Patra Catalog Boot</name>
    <description>Data persistence launcher module - Spring Boot entry point</description>

    <dependencies>
        <!-- Web starter includes core + logging + web + validation -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-web</artifactId>
        </dependency>

        <!-- Consul 服务发现 -->
        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-consul-discovery</artifactId>
        </dependency>

        <!-- HTTP Interface 客户端（替代 Feign） -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-http-interface</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- Patra Observability Starter (包含 OpenTelemetry + Prometheus + Tracing + Logging) -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-observability</artifactId>
        </dependency>

        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-catalog-adapter</artifactId>
        </dependency>
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-catalog-infra</artifactId>
        </dependency>

        <!-- 对象存储 -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-object-storage</artifactId>
        </dependency>

        <!-- Patra Test Starter (包含 TestContainers, ArchUnit, Spring Boot Test, Awaitility 等) -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Elasticsearch Testcontainer (starter-test 未包含) -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>elasticsearch</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Produce an executable Spring Boot fat JAR -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <mainClass>com.patra.catalog.PatraCatalogApplication</mainClass>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
