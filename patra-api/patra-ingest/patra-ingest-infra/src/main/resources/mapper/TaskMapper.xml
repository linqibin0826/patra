<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.patra.ingest.infra.persistence.mapper.TaskMapper">

    <!--
        CAS lease acquisition (step 0)

        Strategy: perform a CAS update only for tasks in QUEUED status that meet:
        1. status_code='QUEUED' AND idempotent_key=#{idem}
        2. scheduled_at IS NULL OR scheduled_at <= #{now} (honors notBefore)
        3. leased_until IS NULL OR leased_until <= #{now} OR lease_owner=#{owner} (stealable)

        Updates: lease_owner, leased_until, lease_count+1

        Returns: number of affected rows (1=success, 0=failed)
    -->
    <update id="tryAcquireLease">
        UPDATE ing_task
           SET lease_owner = #{owner},
               leased_until = DATE_ADD(#{now}, INTERVAL #{ttlSec} SECOND),
               lease_count = lease_count + 1
         WHERE id = #{taskId}
           AND status_code = 'QUEUED'
           AND idempotent_key = #{idem}
           AND (scheduled_at IS NULL OR scheduled_at &lt;= #{now})
           AND (leased_until IS NULL OR leased_until &lt;= #{now} OR lease_owner = #{owner})
    </update>

    <!--
        Mark task RUNNING and update lease (step 1)

        Preconditions: WHERE lease_owner=#{owner} (prevent theft)
        Updates: status_code='RUNNING', started_at, last_heartbeat_at, leased_until

        Returns: affected rows (1=success, 0=lease lost)
    -->
    <update id="markRunningWithLease">
        UPDATE ing_task
           SET status_code = 'RUNNING',
               started_at = #{now},
               last_heartbeat_at = #{now},
               leased_until = DATE_ADD(#{now}, INTERVAL #{ttlSec} SECOND)
         WHERE id = #{taskId}
           AND lease_owner = #{owner}
    </update>

    <!--
        Heartbeat lease renewal

        Preconditions: WHERE lease_owner=#{owner}
        Updates: leased_until, last_heartbeat_at, lease_count+1

        Returns: affected rows (1=success, 0=lease lost)
    -->
    <update id="renewLease">
        UPDATE ing_task
           SET leased_until = DATE_ADD(#{now}, INTERVAL #{ttlSec} SECOND),
               last_heartbeat_at = #{now},
               lease_count = lease_count + 1
         WHERE id = #{taskId}
           AND lease_owner = #{owner}
    </update>

    <!--
        Batch heartbeat lease renewal (performance optimization)

        Strategy: renew leases in batch for multiple tasks owned by the current node to reduce round-trips
        Preconditions: WHERE id IN (taskIds) AND lease_owner=#{owner}
        Updates: leased_until, last_heartbeat_at, lease_count+1

        Returns: affected rows (number of tasks renewed)

        Performance considerations:
        - Use IN clause for small batches (recommend <= 100 tasks/batch)
        - Update only tasks still owned (lease_owner check)
        - Use covering index idx_task_queue (status_code, leased_until, ...) for faster lookups
    -->
    <update id="batchRenewLeases">
        UPDATE ing_task
           SET leased_until = DATE_ADD(#{now}, INTERVAL #{ttlSec} SECOND),
               last_heartbeat_at = #{now},
               lease_count = lease_count + 1
         WHERE id IN
        <foreach collection="taskIds" item="taskId" open="(" separator="," close=")">
            #{taskId}
        </foreach>
           AND lease_owner = #{owner}
    </update>

</mapper>
