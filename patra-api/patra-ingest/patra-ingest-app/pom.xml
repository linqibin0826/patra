    <description>Ingestion application module - application services and use case orchestration</description>

    <dependencies>
        <!-- Common types (ProvenanceCode, etc.) -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-common-core</artifactId>
        </dependency>

        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-ingest-domain</artifactId>
        </dependency>

        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-ingest-api</artifactId>
        </dependency>

        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-core</artifactId>
        </dependency>

        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-spring-boot-starter-expr</artifactId>
        </dependency>

        <!-- Direct use of expression kernel API (com.patra.expr.*) -->
        <dependency>
            <groupId>com.patra</groupId>
            <artifactId>patra-expr-kernel</artifactId>
        </dependency>

