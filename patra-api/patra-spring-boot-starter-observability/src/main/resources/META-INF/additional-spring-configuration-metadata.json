{
  "groups": [
    {
      "name": "patra.observability",
      "type": "com.patra.starter.observability.config.ObservabilityProperties",
      "description": "Patra 可观测性统一配置属性（Agent 模式：Tracing 由 OTel Agent 处理，Metrics 由 Prometheus Pull）"
    },
    {
      "name": "patra.observability.metrics",
      "type": "com.patra.starter.observability.config.ObservabilityProperties$MetricsConfig",
      "description": "指标（Metrics）配置"
    },
    {
      "name": "patra.observability.metrics.prometheus",
      "type": "com.patra.starter.observability.config.ObservabilityProperties$PrometheusConfig",
      "description": "Prometheus Registry 配置"
    },
    {
      "name": "patra.observability.logging",
      "type": "com.patra.starter.observability.config.ObservabilityProperties$LoggingConfig",
      "description": "日志（Logging）配置"
    }
  ],
  "properties": [
    {
      "name": "patra.observability.enabled",
      "type": "java.lang.Boolean",
      "description": "全局开关，是否启用可观测性功能",
      "defaultValue": true
    },
    {
      "name": "patra.observability.application-name",
      "type": "java.lang.String",
      "description": "应用名称标识"
    },
    {
      "name": "patra.observability.environment",
      "type": "java.lang.String",
      "description": "环境标识（dev, staging, prod）",
      "defaultValue": "dev"
    },
    {
      "name": "patra.observability.region",
      "type": "java.lang.String",
      "description": "区域标识"
    },
    {
      "name": "patra.observability.cluster",
      "type": "java.lang.String",
      "description": "集群标识",
      "defaultValue": "default"
    },
    {
      "name": "patra.observability.metrics.enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用指标收集",
      "defaultValue": true
    },
    {
      "name": "patra.observability.metrics.prefix",
      "type": "java.lang.String",
      "description": "指标前缀（可选，默认为空）",
      "defaultValue": ""
    },
    {
      "name": "patra.observability.metrics.prometheus.enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用 Prometheus Registry",
      "defaultValue": true
    },
    {
      "name": "patra.observability.metrics.prometheus.enable-exemplars",
      "type": "java.lang.Boolean",
      "description": "是否启用 Exemplars（与 Tracing 关联）",
      "defaultValue": true
    },
    {
      "name": "patra.observability.logging.enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用日志关联",
      "defaultValue": true
    },
    {
      "name": "patra.observability.logging.include-trace-id",
      "type": "java.lang.Boolean",
      "description": "是否在日志中包含 traceId",
      "defaultValue": true
    }
  ],
  "hints": [
    {
      "name": "patra.observability.environment",
      "values": [
        {
          "value": "dev",
          "description": "开发环境"
        },
        {
          "value": "staging",
          "description": "预发布环境"
        },
        {
          "value": "prod",
          "description": "生产环境"
        }
      ]
    }
  ]
}
