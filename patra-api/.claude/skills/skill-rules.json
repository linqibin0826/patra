{
  "version": "2.0",
  "description": "Skill activation triggers for Patra Java backend - Refactored for specialized skills (Claude Code)",
  "skills": {
    "java-hexagonal-architecture": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Hexagonal Architecture and DDD expert for design and architectural decisions",
      "promptTriggers": {
        "keywords": [
          "hexagonal architecture",
          "DDD",
          "domain-driven design",
          "clean architecture",
          "onion architecture",
          "ports and adapters",
          "architectural decision",
          "bounded context",
          "aggregate",
          "domain model",
          "value object",
          "entity design",
          "dependency rule",
          "layer boundary",
          "module structure",
          "六边形架构",
          "领域驱动设计",
          "洋葱架构",
          "端口适配器",
          "架构决策",
          "界限上下文",
          "聚合根",
          "领域模型",
          "值对象",
          "实体设计",
          "依赖规则",
          "层次边界",
          "模块结构"
        ],
        "intentPatterns": [
          "(design|architect|structure).*?(system|module|service|domain)",
          "(how to|best practice).*?(hexagonal|DDD|architecture|domain model)",
          "(evaluate|review|assess).*?architecture",
          "(refactor|restructure).*?(to|into).*?(hexagonal|DDD)",
          "(设计|架构|构建).*(系统|模块|服务|领域)",
          "(如何|最佳实践).*(六边形|DDD|架构|领域模型)",
          "(评估|评审|审查).*架构",
          "(重构|改造).*(六边形|DDD)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/patra-*-domain/src/**/*.java",
          "**/ARCHITECTURE.md",
          "**/docs/architecture/**",
          "**/docs/design/**"
        ]
      }
    },
    "java-spring-development": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Spring Boot microservices development with MyBatis-Plus and MapStruct",
      "promptTriggers": {
        "keywords": [
          "Spring Boot",
          "Spring Cloud",
          "controller",
          "REST API",
          "endpoint",
          "orchestrator",
          "coordinator",
          "repository implementation",
          "MyBatis-Plus",
          "MapStruct",
          "@Transactional",
          "transaction management",
          "XXL-Job",
          "scheduled task",
          "Nacos",
          "configuration",
          "控制器",
          "REST接口",
          "端点",
          "编排器",
          "协调器",
          "仓储实现",
          "事务管理",
          "定时任务",
          "配置管理"
        ],
        "intentPatterns": [
          "(create|implement|add).*?(controller|endpoint|API|orchestrator|coordinator|repository)",
          "(configure|setup).*?(Spring|MyBatis|transaction|Nacos)",
          "(implement|add).*?(scheduled job|XXL-Job|task)",
          "(创建|实现|添加).*(controller|控制器|接口|编排器|协调器|仓储)",
          "(配置|设置).*(Spring|MyBatis|事务|Nacos)",
          "(实现|添加).*(定时任务|XXL-Job)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/patra-*-adapter/src/**/*.java",
          "**/patra-*-app/src/**/*.java",
          "**/patra-*-infra/src/**/*.java",
          "**/patra-*-boot/src/**/*.java"
        ],
        "contentPatterns": [
          "@RestController",
          "@Service",
          "@Repository",
          "@Transactional",
          "@XxlJob",
          "@Mapper",
          "class.*Orchestrator",
          "class.*Coordinator",
          "implements.*Port"
        ]
      }
    },
    "java-test-architect": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Test generation expert for unit tests, integration tests, and ArchUnit tests",
      "promptTriggers": {
        "keywords": [
          "test",
          "testing",
          "unit test",
          "integration test",
          "ArchUnit",
          "TestContainers",
          "MockMvc",
          "Mockito",
          "JUnit",
          "test coverage",
          "TDD",
          "test pyramid",
          "idempotency test",
          "optimistic lock test",
          "测试",
          "单元测试",
          "集成测试",
          "测试覆盖率",
          "测试金字塔",
          "幂等性测试",
          "乐观锁测试"
        ],
        "intentPatterns": [
          "(write|create|generate|add).*?test",
          "(test|testing).*?(domain|orchestrator|coordinator|repository|controller)",
          "(improve|increase).*?coverage",
          "(写|创建|生成|添加).*测试",
          "测试.*(领域|编排器|协调器|仓储|控制器)",
          "(提高|增加).*覆盖率"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/src/test/**/*.java",
          "**/*Test.java",
          "**/*IT.java",
          "**/*Tests.java"
        ]
      }
    },
    "java-runtime-diagnostic": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Runtime error diagnosis and performance analysis expert",
      "promptTriggers": {
        "keywords": [
          "error",
          "exception",
          "stack trace",
          "debug",
          "troubleshoot",
          "performance",
          "memory leak",
          "thread dump",
          "heap dump",
          "SkyWalking",
          "log analysis",
          "optimistic lock failure",
          "transaction rollback",
          "NullPointerException",
          "OutOfMemoryError",
          "错误",
          "异常",
          "堆栈跟踪",
          "调试",
          "故障排查",
          "性能",
          "内存泄漏",
          "线程转储",
          "堆转储",
          "日志分析",
          "乐观锁失败",
          "事务回滚"
        ],
        "intentPatterns": [
          "(fix|debug|troubleshoot|diagnose).*?(error|exception|issue|problem)",
          "(analyze|investigate).*?(performance|memory|thread)",
          "(why|what causes).*?(error|exception|failure)",
          "(修复|调试|排查|诊断).*(错误|异常|问题)",
          "(分析|调查).*(性能|内存|线程)",
          "(为什么|什么原因).*(错误|异常|失败)"
        ]
      }
    },
    "java-code-reviewer": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Code review and architecture compliance expert",
      "promptTriggers": {
        "keywords": [
          "code review",
          "review code",
          "check architecture",
          "compliance check",
          "code quality",
          "refactor",
          "anti-pattern",
          "design pattern",
          "dependency violation",
          "代码审查",
          "审查代码",
          "架构检查",
          "合规检查",
          "代码质量",
          "重构",
          "反模式",
          "设计模式",
          "依赖违规"
        ],
        "intentPatterns": [
          "(review|check|audit|assess).*?(code|architecture|compliance)",
          "(identify|find).*?(issue|problem|violation|anti-pattern)",
          "(improve|refactor).*?code",
          "(审查|检查|评审|评估).*(代码|架构|合规)",
          "(识别|查找).*(问题|违规|反模式)",
          "(改进|重构).*代码"
        ]
      }
    },
    "java-documentation-architect": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Documentation architect for README, JavaDoc, and architectural decision records",
      "promptTriggers": {
        "keywords": [
          "documentation",
          "document",
          "README",
          "JavaDoc",
          "package-info",
          "API documentation",
          "ADR",
          "architectural decision record",
          "PlantUML",
          "diagram",
          "文档",
          "文档化",
          "架构决策记录",
          "架构图"
        ],
        "intentPatterns": [
          "(write|create|update|generate).*?(documentation|README|JavaDoc)",
          "(document|describe).*?(API|architecture|module)",
          "(create|draw).*?diagram",
          "(写|创建|更新|生成).*(文档|README|JavaDoc)",
          "(文档化|描述).*(API|架构|模块)",
          "(创建|绘制).*图"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/README.md",
          "**/package-info.java",
          "**/docs/**/*.md",
          "**/*.puml"
        ]
      }
    }
  }
}