{
  "version": "1.0",
  "description": "Skill activation triggers for Papertrace Java backend (Claude Code)",
  "skills": {
    "skill-developer": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Meta-skill for creating and managing Claude Code skills",
      "promptTriggers": {
        "keywords": [
          "skill system",
          "create skill",
          "add skill",
          "skill triggers",
          "skill rules",
          "hook system",
          "skill development",
          "skill-rules.json"
        ],
        "intentPatterns": [
          "(how do|how does|explain).*?skill",
          "(create|add|modify|build).*?skill",
          "skill.*?(work|trigger|activate|system)"
        ]
      }
    },
    "java-backend-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Java/Spring Boot backend development patterns for Hexagonal Architecture + DDD",
      "promptTriggers": {
        "keywords": [
          "backend",
          "backend development",
          "microservice",
          "controller",
          "orchestrator",
          "coordinator",
          "adapter",
          "domain",
          "entity",
          "aggregate",
          "repository",
          "REST",
          "API",
          "endpoint",
          "Spring Boot",
          "Spring MVC",
          "validation",
          "MyBatis-Plus",
          "MapStruct",
          "Hexagonal Architecture",
          "DDD",
          "domain-driven design",
          "dependency injection",
          "configuration",
          "Nacos",
          "port",
          "driven adapter",
          "driving adapter",
          "value object",
          "domain event",
          "outbox pattern",
          "transaction",
          "persistence"
        ],
        "intentPatterns": [
          "(create|add|implement|build).*?(controller|endpoint|API|orchestrator|adapter|entity|aggregate|repository|domain)",
          "(fix|handle|debug).*?(error|exception|backend|compilation)",
          "(add|implement).*?(validation|error.*?handling|filter|interceptor|middleware)",
          "(organize|structure|refactor).*?(backend|service|API|domain|module)",
          "(how to|best practice).*?(backend|hexagonal|DDD|domain|orchestrator|transaction)",
          "(test|testing).*?(domain|orchestrator|repository|adapter)",
          "(database|persistence|MyBatis).*?(query|mapping|DO|converter)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "patra-*/patra-*-adapter/src/**/*.java",
          "patra-*/patra-*-app/src/**/*.java",
          "patra-*/patra-*-domain/src/**/*.java",
          "patra-*/patra-*-infra/src/**/*.java",
          "patra-*/patra-*-api/src/**/*.java",
          "patra-*/patra-*-boot/src/**/*.java",
          "patra-ingest/**/*.java",
          "patra-registry/**/*.java",
          "patra-storage/**/*.java",
          "patra-catalog/**/*.java",
          "patra-gateway-boot/**/*.java",
          "patra-common/**/*.java",
          "patra-expr-kernel/**/*.java",
          "patra-spring-boot-starter-*/**/*.java"
        ],
        "pathExclusions": [
          "**/*Test.java",
          "**/test/**",
          "**/*IT.java",
          "**/target/**"
        ],
        "contentPatterns": [
          "@RestController",
          "@Service",
          "@Repository",
          "implements.*Port",
          "class.*Orchestrator",
          "class.*Coordinator",
          "@Transactional",
          "MyBatis",
          "@Mapper",
          "@TableName",
          "@XxlJob",
          "@RocketMQMessageListener",
          "record.*\\{",
          "DomainEvent",
          "@Data",
          "@Slf4j"
        ]
      }
    },
    "logging-observability": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Logging, tracing, and error handling patterns (SLF4J, Micrometer)",
      "promptTriggers": {
        "keywords": [
          "error handling",
          "exception",
          "logging",
          "log",
          "SLF4J",
          "error tracking",
          "monitoring",
          "performance tracking",
          "tracing",
          "trace",
          "traceId",
          "metrics",
          "Micrometer",
          "observability"
        ],
        "intentPatterns": [
          "(add|implement|improve).*?(logging|error.*?handling|monitoring|tracing)",
          "(log|trace).*?(error|exception|event|metric)",
          "(how to|best practice).*?(log|logging|error.*?handling|tracing)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "patra-*/**/*.java"
        ],
        "pathExclusions": [
          "**/*Test.java",
          "**/test/**"
        ],
        "contentPatterns": [
          "@Slf4j",
          "log\\.(error|warn|info|debug)",
          "@ControllerAdvice",
          "ExceptionHandler",
          "ProblemDetail",
          "traceId",
          "spanId"
        ]
      }
    },
    "papertrace-domain": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Papertrace business domain knowledge: Provenance, Plan, Task, Expression engine, and workflow patterns",
      "promptTriggers": {
        "keywords": [
          "provenance",
          "provenance configuration",
          "provenance code",
          "plan",
          "batch plan",
          "plan slicing",
          "task",
          "batch task",
          "slice",
          "slicing",
          "window",
          "time window",
          "window offset",
          "expression",
          "expression engine",
          "capability",
          "render rule",
          "expr field",
          "business key",
          "idempotency",
          "temporal slicing",
          "scope precedence",
          "pagination config",
          "http config",
          "retry config",
          "rate limit",
          "batching config",
          "PubMed",
          "EPMC",
          "Crossref",
          "literature",
          "harvest",
          "ingest"
        ],
        "intentPatterns": [
          "(how|explain|understand|what is).*?(provenance|plan|task|slice|window|expression)",
          "(configure|setup|create).*?(provenance|plan|window|pagination|expression)",
          "(debug|troubleshoot|fix).*?(plan|task|expression|slicing|configuration)",
          "(implement|add|build).*?(provenance.*?config|plan.*?slice|task.*?workflow|expression.*?engine)",
          "(temporal|time).*?(slice|slicing|window)",
          "business.*?key",
          "scope.*?precedence"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "patra-registry/**/*.java",
          "patra-ingest/**/*.java",
          "patra-expr-kernel/**/*.java"
        ],
        "pathExclusions": [
          "**/*Test.java",
          "**/test/**",
          "**/*IT.java"
        ],
        "contentPatterns": [
          "Provenance",
          "ProvenanceConfig",
          "BatchPlan",
          "BatchTask",
          "Slice",
          "WindowOffset",
          "Expression",
          "ExprField",
          "Capability",
          "RenderRule",
          "PaginationConfig",
          "HttpConfig",
          "RetryConfig",
          "RateLimitConfig",
          "BatchingConfig",
          "businessKey",
          "TemporalSlicing",
          "ScopePrecedence"
        ]
      }
    }
  }
}
