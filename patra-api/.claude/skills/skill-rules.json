{
  "version": "1.0",
  "description": "Skill activation triggers for Papertrace Java backend (Claude Code)",
  "skills": {
    "skill-developer": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Meta-skill for creating and managing Claude Code skills",
      "promptTriggers": {
        "keywords": [
          "skill system",
          "create skill",
          "add skill",
          "skill triggers",
          "skill rules",
          "hook system",
          "skill development",
          "skill-rules.json"
        ],
        "intentPatterns": [
          "(how do|how does|explain).*?skill",
          "(create|add|modify|build).*?skill",
          "skill.*?(work|trigger|activate|system)"
        ]
      }
    },
    "java-backend-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Comprehensive Java backend development guide for Hexagonal Architecture + DDD with Spring Boot 3.5.7",
      "promptTriggers": {
        "keywords": [
          "backend",
          "backend development",
          "microservice",
          "controller",
          "orchestrator",
          "coordinator",
          "adapter",
          "domain",
          "entity",
          "aggregate",
          "repository",
          "REST",
          "API",
          "endpoint",
          "Spring Boot",
          "Spring MVC",
          "validation",
          "MyBatis-Plus",
          "MapStruct",
          "Hexagonal Architecture",
          "DDD",
          "domain-driven design",
          "dependency injection",
          "configuration",
          "Nacos",
          "port",
          "driven adapter",
          "driving adapter",
          "value object",
          "domain event",
          "event handler",
          "event chain",
          "outbox pattern",
          "outbox relay",
          "outbox message",
          "transaction",
          "persistence",
          "scheduled job",
          "XXL-Job",
          "template method",
          "lease coordination",
          "optimistic locking",
          "idempotency",
          "exponential backoff",
          "transactional event listener",
          "AFTER_COMMIT",
          "REQUIRES_NEW",
          "plan ingestion",
          "slice status",
          "task completion",
          "relay coordinator",
          "publish coordinator",
          "lease coordinator",
          "log coordinator"
        ],
        "intentPatterns": [
          "(create|add|implement|build).*?(controller|endpoint|API|orchestrator|coordinator|adapter|entity|aggregate|repository|domain|job)",
          "(fix|handle|debug).*?(error|exception|backend|compilation|event|relay|lease)",
          "(add|implement).*?(validation|error.*?handling|filter|interceptor|middleware|event.*?handler)",
          "(organize|structure|refactor).*?(backend|service|API|domain|module|orchestrator)",
          "(how to|best practice).*?(backend|hexagonal|DDD|domain|orchestrator|coordinator|transaction|outbox|event)",
          "(test|testing).*?(domain|orchestrator|coordinator|repository|adapter|event.*?handler)",
          "(database|persistence|MyBatis).*?(query|mapping|DO|converter)",
          "(implement|add|setup).*?(outbox.*?pattern|event.*?driven|relay|lease|domain.*?event)",
          "(schedule|job|XXL).*?(task|execution|trigger)",
          "(lease|coordination|concurrent).*?(acquire|release|conflict)",
          "(publish|relay|message).*?(event|outbox|MQ|queue)",
          "(handle|process).*?(event|completion|status.*?change)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/patra-*-adapter/src/**/*.java",
          "**/patra-*-app/src/**/*.java",
          "**/patra-*-domain/src/**/*.java",
          "**/patra-*-infra/src/**/*.java",
          "**/patra-*-api/src/**/*.java",
          "**/patra-*-boot/src/**/*.java",
          "patra-ingest/**/*.java",
          "patra-registry/**/*.java",
          "patra-storage/**/*.java",
          "patra-catalog/**/*.java",
          "patra-gateway-boot/**/*.java",
          "patra-common/**/*.java",
          "patra-expr-kernel/**/*.java",
          "patra-spring-boot-starter-*/**/*.java"
        ],
        "pathExclusions": [
          "**/*Test.java",
          "**/test/**",
          "**/*IT.java",
          "**/target/**"
        ],
        "contentPatterns": [
          "@RestController",
          "@Service",
          "@Repository",
          "@Component",
          "implements.*Port",
          "class.*Orchestrator",
          "class.*Coordinator",
          "class.*Job",
          "@Transactional",
          "@TransactionalEventListener",
          "TransactionPhase\\.AFTER_COMMIT",
          "Propagation\\.REQUIRES_NEW",
          "MyBatis",
          "@Mapper",
          "@TableName",
          "@XxlJob",
          "@RocketMQMessageListener",
          "record.*\\{",
          "DomainEvent",
          ".*Event\\(",
          ".*Event\\{",
          "OutboxMessage",
          "OutboxRelay",
          "RelayCoordinator",
          "RelayExecutor",
          "RelayPlan",
          "RelayBatchResult",
          "LeaseCoordinator",
          "PublishCoordinator",
          "LogCoordinator",
          "TaskCompletedEvent",
          "SliceStatusChangedEvent",
          "OutboxMessagePublishedEvent",
          "OutboxMessageDeferredEvent",
          "OutboxMessageFailedEvent",
          "OutboxLeaseMissedEvent",
          "PlanIngestionCommand",
          "PlanIngestionOrchestrator",
          "PlanPersistenceCoordinator",
          "PlanIdempotencyCoordinator",
          "AbstractProvenanceScheduleJob",
          "OptimisticLockingFailureException",
          "ApplicationEventPublisher",
          "@Data",
          "@Slf4j",
          "@RequiredArgsConstructor",
          "@Builder"
        ]
      }
    },
    "papertrace-domain": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Papertrace business domain knowledge: Provenance, Plan, Task, Expression engine, and workflow patterns",
      "promptTriggers": {
        "keywords": [
          "provenance",
          "provenance configuration",
          "provenance code",
          "plan",
          "batch plan",
          "plan slicing",
          "task",
          "batch task",
          "slice",
          "slicing",
          "window",
          "time window",
          "window offset",
          "expression",
          "expression engine",
          "capability",
          "render rule",
          "expr field",
          "business key",
          "idempotency",
          "temporal slicing",
          "scope precedence",
          "pagination config",
          "http config",
          "retry config",
          "rate limit",
          "batching config",
          "PubMed",
          "EPMC",
          "Crossref",
          "literature",
          "harvest",
          "ingest"
        ],
        "intentPatterns": [
          "(how|explain|understand|what is).*?(provenance|plan|task|slice|window|expression)",
          "(configure|setup|create).*?(provenance|plan|window|pagination|expression)",
          "(debug|troubleshoot|fix).*?(plan|task|expression|slicing|configuration)",
          "(implement|add|build).*?(provenance.*?config|plan.*?slice|task.*?workflow|expression.*?engine)",
          "(temporal|time).*?(slice|slicing|window)",
          "business.*?key",
          "scope.*?precedence"
