          "**/*IT.java"
        ],
        "contentPatterns": [
          "Provenance",
          "ProvenanceConfig",
          "BatchPlan",
          "BatchTask",
          "Slice",
          "WindowOffset",
          "Expression",
          "ExprField",
          "Capability",
          "RenderRule",
