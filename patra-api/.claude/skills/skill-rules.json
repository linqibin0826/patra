{
  "version": "2.0",
  "description": "Skill activation triggers for Patra Java backend - Refactored for specialized skills (Claude Code)",
  "skills": {
    "java-hexagonal-architecture": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Hexagonal Architecture and DDD expert for design and architectural decisions",
      "promptTriggers": {
        "keywords": [
          "hexagonal architecture",
          "DDD",
          "domain-driven design",
          "clean architecture",
          "onion architecture",
          "ports and adapters",
          "architectural decision",
          "bounded context",
          "aggregate",
          "domain model",
          "value object",
          "entity design",
          "dependency rule",
          "layer boundary",
          "module structure",
          "六边形架构",
          "领域驱动设计",
          "洋葱架构",
          "端口适配器",
          "架构决策",
          "界限上下文",
          "聚合根",
          "领域模型",
          "值对象",
          "实体设计",
          "依赖规则",
          "层次边界",
          "模块结构"
        ],
        "intentPatterns": [
          "(design|architect|structure).*?(system|module|service|domain)",
          "(how to|best practice).*?(hexagonal|DDD|architecture|domain model)",
          "(evaluate|review|assess).*?architecture",
          "(refactor|restructure).*?(to|into).*?(hexagonal|DDD)",
          "(设计|架构|构建).*(系统|模块|服务|领域)",
          "(如何|最佳实践).*(六边形|DDD|架构|领域模型)",
          "(评估|评审|审查).*架构",
          "(重构|改造).*(六边形|DDD)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/patra-*-domain/src/**/*.java",
          "**/ARCHITECTURE.md",
          "**/docs/architecture/**",
          "**/docs/design/**"
        ]
      }
    },
    "java-runtime-diagnostic": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Runtime error diagnosis and performance analysis expert",
      "promptTriggers": {
        "keywords": [
          "error",
          "exception",
          "stack trace",
          "debug",
          "troubleshoot",
          "performance",
          "memory leak",
          "thread dump",
          "heap dump",
          "SkyWalking",
          "log analysis",
          "optimistic lock failure",
          "transaction rollback",
          "NullPointerException",
          "OutOfMemoryError",
          "错误",
          "异常",
          "堆栈跟踪",
          "调试",
          "故障排查",
          "性能",
          "内存泄漏",
          "线程转储",
          "堆转储",
          "日志分析",
          "乐观锁失败",
          "事务回滚"
        ],
        "intentPatterns": [
          "(fix|debug|troubleshoot|diagnose).*?(error|exception|issue|problem)",
          "(analyze|investigate).*?(performance|memory|thread)",
          "(why|what causes).*?(error|exception|failure)",
          "(修复|调试|排查|诊断).*(错误|异常|问题)",
          "(分析|调查).*(性能|内存|线程)",
          "(为什么|什么原因).*(错误|异常|失败)"
        ]
      }
    },
    "java-documentation-architect": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Documentation architect for README, JavaDoc, and architectural decision records",
      "promptTriggers": {
        "keywords": [
          "documentation",
          "document",
          "README",
          "JavaDoc",
          "package-info",
          "API documentation",
          "ADR",
          "architectural decision record",
          "PlantUML",
          "diagram",
          "文档",
          "文档化",
          "架构决策记录",
          "架构图"
        ],
        "intentPatterns": [
          "(write|create|update|generate).*?(documentation|README|JavaDoc)",
          "(document|describe).*?(API|architecture|module)",
          "(create|draw).*?diagram",
          "(写|创建|更新|生成).*(文档|README|JavaDoc)",
          "(文档化|描述).*(API|架构|模块)",
          "(创建|绘制).*图"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/README.md",
          "**/package-info.java",
          "**/docs/**/*.md",
          "**/*.puml"
        ]
      }
    },
    "database-modeling": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "MySQL database design expert with progressive disclosure approach. Supports ER diagram, table design, SQL DDL generation, domain model mapping, and design decision records. Specialized for MySQL 8.0 + MyBatis-Plus + Hexagonal Architecture + DDD.",
      "promptTriggers": {
        "keywords": [
          "database design",
          "table design",
          "table structure",
          "ER diagram",
          "Mermaid ER",
          "SQL DDL",
          "CREATE TABLE",
          "ALTER TABLE",
          "index",
          "索引",
          "audit fields",
          "database modeling",
          "normalization",
          "foreign key",
          "unique constraint",
          "optimistic lock",
          "soft delete",
          "TIMESTAMP",
          "BIGINT",
          "VARCHAR",
          "MySQL",
          "database optimization",
          "index selectivity",
          "ADR",
          "数据库设计",
          "表设计",
          "表结构",
          "ER图",
          "实体关系图",
          "建表",
          "索引优化",
          "审计字段",
          "数据库建模",
          "范式",
          "外键",
          "唯一约束",
          "乐观锁",
          "软删除",
          "数据库优化",
          "索引选择性",
          "领域模型映射",
          "DO mapping",
          "MyBatis-Plus",
          "field design",
          "字段设计",
          "column design",
          "列设计"
        ],
        "intentPatterns": [
          "(design|create|build).*?(database|table|schema)",
          "(draw|create|generate).*?(ER diagram|entity relationship)",
          "(generate|create|write).*?(SQL|DDL|CREATE TABLE)",
          "(design|optimize).*?(index|索引)",
          "(map|generate).*?(domain model|DO|entity)",
          "(设计|创建|构建).*(数据库|表|模式)",
          "(绘制|创建|生成).*(ER图|实体关系图)",
          "(生成|创建|编写).*(SQL|DDL|建表语句)",
          "(设计|优化).*(索引)",
          "(映射|生成).*(领域模型|DO|实体)",
          "(需求分析|表设计|字段设计|索引设计)",
          "如何.*?(设计|优化).*(数据库|表|索引)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/*.sql",
          "**/migration/**/*.sql",
          "**/db/**/*.sql",
          "**/schema/**/*.sql",
          "**/ddl/**/*.sql",
          "**/database/**/*.md",
          "**/db-design/**/*.md",
          "**/*DO.java",
          "**/entity/*DO.java",
          "**/persistence/entity/**/*.java"
        ],
        "contentPatterns": [
          "CREATE TABLE",
          "ALTER TABLE",
          "DROP TABLE",
          "ADD INDEX",
          "ADD CONSTRAINT",
          "@TableName",
          "@TableId",
          "@TableField",
          "@TableLogic",
          "extends BaseDO",
          "erDiagram"
        ]
      }
    }
  }
}