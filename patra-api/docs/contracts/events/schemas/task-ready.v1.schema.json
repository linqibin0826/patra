  "$id": "https://papertrace.dev/contracts/events/task-ready.v1.schema.json",
  "title": "TaskReady v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "taskId": {
      "type": "integer",
      "minimum": 1
    },
    "idempotentKey": {
