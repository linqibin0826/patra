<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Use Spring Boot's default console pattern -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Property for application name (fallback to "application") -->
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="application"/>

    <!-- Property for log file path (relative to module root) -->
    <property name="LOG_PATH" value="logs"/>
    <property name="LOG_FILE" value="${LOG_PATH}/${appName}"/>

    <!-- Custom file log pattern with distributed tracing -->
    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [${appName},%X{traceId:-},%X{spanId:-}] [%t] %-40.40logger{39} : %m%n%wEx"/>

    <!-- Console Appender (DEBUG level, using Spring Boot's default pattern) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File Appender (INFO level, custom pattern with tracing) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}.log</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>

        <!-- Rolling Policy -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Daily rollover with max file size -->
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- Each file max size -->
            <maxFileSize>100MB</maxFileSize>
            <!-- Total size of all archive files, if exceeded, oldest files deleted -->
            <totalSizeCap>10GB</totalSizeCap>
            <!-- Keep logs for 30 days -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <!-- Filter: only INFO and above -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- Root Logger: INFO level (default for all libraries) -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- Application Logger: DEBUG level (only for com.patra.* classes) -->
    <logger name="com.patra" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

</configuration>
