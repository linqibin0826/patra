# RocketMQ 配置
# 设置宿主机 IP 以便从宿主机访问 RocketMQ broker
# 留空则自动检测（可能不准确）
BROKER_IP1=

# 如何获取宿主机 IP:
# macOS: ifconfig | grep "inet " | grep -v 127.0.0.1 | head -1 | awk '{print $2}'
# Linux: hostname -I | awk '{print $1}'
# 或手动填写，例如: BROKER_IP1=192.168.1.13

# mysql-ops 凭据（运维组件用 MySQL，业务库走 PG）
# 复制到 .env.dev 后改成本地实际值
MYSQL_OPS_ROOT_PASSWORD=
MYSQL_OPS_USERNAME=xxl_job
MYSQL_OPS_PASSWORD=

# ----- Nacos 鉴权 -----
# 复制到 .env 后用以下命令生成真实值替换占位：
#   openssl rand -base64 32   # NACOS_AUTH_TOKEN
#   openssl rand -base64 24   # NACOS_AUTH_IDENTITY_VALUE
NACOS_AUTH_TOKEN=
NACOS_AUTH_IDENTITY_KEY=patra
NACOS_AUTH_IDENTITY_VALUE=
