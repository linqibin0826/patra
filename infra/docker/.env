# Patra 基础设施 - 环境变量
# ==============================================================
# 本文件由 docker-compose 自动加载（与 compose 文件同目录的 .env）
# Mac mini 部署模式下，所有 host 字段统一走 tailscale MagicDNS。

# ----- RocketMQ Broker 对外地址 -----
# 客户端从 NameServer 拿到此地址后直连 broker，必须是客户端能解析+访问的。
# 默认走 MagicDNS 短名（家内自动解析为 LAN IP，离家自动解析为 tailscale IP）。
# 如需切换为 FQDN 回退（极少数客户端解析问题），改为：
#   BROKER_IP1=linqibins-mac-mini.taild06182.ts.net
BROKER_IP1=linqibins-mac-mini

# ----- mysql-ops 凭据（仅供 xxl-job-admin 使用；业务库走 PG）-----
# 这些变量在 docker-compose.jobs.yaml 中无 fallback，必须在此处或环境注入。
# .env.dev 中亦有同名变量副本，docker compose 默认只读 .env，所以以本文件为准。
MYSQL_OPS_ROOT_PASSWORD=patra_ops_root_dev
MYSQL_OPS_USERNAME=xxl_job
MYSQL_OPS_PASSWORD=xxl_job_dev

# ----- Nacos 鉴权（compose 必须）-----
# 三个值必须就地填充，否则 nacos-server 启动失败。
# 生成命令：
#   NACOS_AUTH_TOKEN     :  openssl rand -base64 32     # 解码后必须 >= 32 字节
#   NACOS_AUTH_IDENTITY  :  openssl rand -base64 24     # KEY/VALUE 任意非空字符串即可
# 注意：此处填充的是 dev 默认值；生产必须改密并由 vault/外部 secret 注入。
NACOS_AUTH_TOKEN=VYeriMvT01Lr362+Tqb56vcOvHiP2l6TAkmKfELCJYo=
NACOS_AUTH_IDENTITY_KEY=patra
NACOS_AUTH_IDENTITY_VALUE=vCooko1cd0buPFa8ISGpcrWbln/m9xRE
