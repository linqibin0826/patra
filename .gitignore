##############################
# OS files
##############################
.DS_Store
Thumbs.db

##############################
# IDEs / Editors
##############################
# IntelliJ IDEA
.idea
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/

# Obsidian
docs/.obsidian/

# Eclipse (in case someone opens with Eclipse)
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

##############################
# Build outputs
##############################
target/
build/
bin/
!**/src/main/**/build/
!**/src/test/**/build/

##############################
# Gradle
##############################
# Gradle cache (root and subprojects)
.gradle/
**/.gradle/

# Kotlin compiler cache (build-logic uses Kotlin DSL)
.kotlin/
**/.kotlin/

# Gradle wrapper jar - should be tracked for reproducible builds
!gradle/wrapper/gradle-wrapper.jar

# Local Gradle configuration (user-specific)
gradle-local.properties

##############################
# Logs & diagnostics
##############################
logs/
*.log
hs_err_pid*
replay_pid*
heapdump.hprof

##############################
# Python
##############################
__pycache__/
*.pyc

##############################
# Env files (local only)
##############################
/.env
/.env.*

##############################
# Claude Code
##############################
# Node.js dependencies for hooks
.claude/hooks/node_modules/
.claude/hooks/package-lock.json

# Hook execution state (session-specific)
.claude/hooks/state/

# Hook tmp files (auto-generated per Java file modification)
.claude/hooks/.java-files-modified

# Backup directories
.claude.backup-*/

# Git worktrees
.worktrees/
.claude/worktrees/

# JAR files (except Gradle wrapper)
*.jar
!gradle/wrapper/gradle-wrapper.jar

# Serena MCP local config
.serena/

# brainstorming visual-companion 会话持久化目录（不要与 docs/patra/ 文档目录混淆）
.patra/

##############################
# Patra workspace 独有规则
##############################
# macOS 系统垃圾
.AppleDouble
.LSOverride

# 通用编辑器残留
*.swp
*.swo
*~

# Patra workspace 临时 / 备份目录
*.backup
*.stale

# Claude Code 本地偏好（不入版本）
.claude/settings.local.json
