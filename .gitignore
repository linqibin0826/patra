##############################
# OS files
##############################
.DS_Store
Thumbs.db

##############################
# IDEs / Editors
##############################
# IntelliJ IDEA
.idea
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/

# Obsidian
docs/.obsidian/

# Eclipse (in case someone opens with Eclipse)
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

##############################
# Build outputs
##############################
target/
build/
bin/
!**/src/main/**/build/
!**/src/test/**/build/

##############################
# Gradle
##############################
# Gradle cache (root and subprojects)
.gradle/
**/.gradle/

# Kotlin compiler cache (build-logic uses Kotlin DSL)
.kotlin/
**/.kotlin/

# Gradle wrapper jar - should be tracked for reproducible builds
!gradle/wrapper/gradle-wrapper.jar

# Local Gradle configuration (user-specific)
gradle-local.properties

##############################
# Logs & diagnostics
##############################
logs/
*.log
hs_err_pid*
replay_pid*
heapdump.hprof

##############################
# Env files (local only)
##############################
.env
.env.*

##############################
# Claude Code
##############################
# Node.js dependencies for hooks
.claude/hooks/node_modules/
.claude/hooks/package-lock.json

# Hook execution state (session-specific)
.claude/hooks/state/

# Backup directories
.claude.backup-*/

# JAR files (except Gradle wrapper)
*.jar
!gradle/wrapper/gradle-wrapper.jar
