          "create service",
          "实现功能",
          "实现业务逻辑",
          "创建服务",
          "开发功能",
          "业务开发"
        ],
        "intentPatterns": [
          "(TDD|test-driven|test-first).*?(develop|implement|create)",
          "(implement|create|add).*?(feature|business logic|service|function)",
          "(implement|create|add).*?(controller|endpoint|API|orchestrator|coordinator|repository)",
          "(configure|setup).*?(Spring|MyBatis|transaction|Nacos)",
          "(implement|add).*?(scheduled job|XXL-Job|task)",
          "(测试驱动|测试先行).*?(开发|实现)",
          "(实现|创建|添加).*(功能|业务逻辑|服务)",
          "(创建|实现|添加).*(controller|控制器|接口|编排器|协调器|仓储)",
          "(配置|设置).*(Spring|MyBatis|事务|Nacos)",
          "(实现|添加).*(定时任务|XXL-Job)",
          "先.*?测试.*?再.*?(代码|实现)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "**/patra-*-domain/src/**/*.java",
          "**/patra-*-app/src/**/*.java",
          "**/patra-*-adapter/src/**/*.java",
          "**/patra-*-infra/src/**/*.java",
          "**/patra-*-boot/src/**/*.java",
          "**/src/test/**/*.java",
          "**/*Test.java",
          "**/*IT.java",
          "**/*E2E.java"
