        "contentPatterns": [
          "@RestController",
          "@Service",
          "@Repository",
          "@Transactional",
          "@XxlJob",
          "@Mapper",
          "class.*Orchestrator",
          "class.*Coordinator",
          "implements.*Port",
          "@Test",
          "@DisplayName"
        ]
      }
